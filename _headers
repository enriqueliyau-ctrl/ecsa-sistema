/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: SAMEORIGIN

/*.html
  Cache-Control: no-cache
  Content-Security-Policy: script-src 'self' 'unsafe-inline' https://www.gstatic.com https://apis.google.com https://cdn.jsdelivr.net https://cdnjs.cloudflare.com

/index.html
  Cache-Control: no-cache, no-store, must-revalidate
